date-released: 2026-06-26
doi: "10.5281/zenodo.20906544"
repository-code: "https://github.com/ferdiazfer/quickscan"
url: "https://ferdiazfer.github.io/quickscan/"
keywords:
  - "optical mark recognition"
  - "OMR"
  - "bubble sheet"
  - "Scantron"
  - "exam grading"
  - "assessment"
  - "item analysis"
  - "psychometrics"
  - "education"
